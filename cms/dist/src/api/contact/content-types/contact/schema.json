{
    "kind": "collectionType",
    "collectionName": "contacts",
    "info": {
        "singularName": "contact",
        "pluralName": "contacts",
        "displayName": "contact"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "fullName": {
            "type": "string"
        },
        "email": {
            "type": "email"
        },
        "phone": {
            "type": "integer"
        },
        "intent": {
            "type": "enumeration",
            "enum": [
                "I want to Buy",
                "I want to Rent",
                "I want to Sell",
                "Just exploring"
            ]
        },
        "message": {
            "type": "blocks"
        }
    }
}
