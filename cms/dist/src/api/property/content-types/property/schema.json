            "enum": [
                "Apartment",
                "Villa",
                "Penthouse",
                "Plot"
            ]
        },
        "location": {
            "type": "string"
        },
        "price": {
            "type": "string"
        },
        "priceRaw": {
            "type": "decimal"
        },
        "baths": {
            "type": "integer"
